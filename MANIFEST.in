include LICENSE
include README.md
include pyproject.toml
include setup.py
include requirements.txt
recursive-include xvortices *.py *.typed *.c *.f90 meson.build
recursive-include tests *.py
recursive-include scripts *.py
recursive-include notebooks *.ipynb
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.so
global-exclude *.pyd
global-exclude *.dll
global-exclude *.dylib
global-exclude *.dll.a
global-exclude *.o
global-exclude *.obj
prune xvortices/build
